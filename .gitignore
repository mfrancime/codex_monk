# bytecode + caches
__pycache__/
*.pyc
*.pyo

# shared-memory fabric files end up here on Linux dev boxes
*.fabric

# transient runtime data — the swarm writes audit jsonl into ./graph
# at runtime; the directory is committed for shape (empty) but its
# contents are not.
/graph/*.jsonl
/graph/*.log

# the durable wargame evolution record lives in ./wargame/ (tracked); the
# web tab's regenerated data file web/wargame.json is tracked too — that is
# the committed "evolution progress" pushed each round.

# orphan temp files left by half-finished pip operations
/requirements.txt.tmp.*

# editor + OS
.vscode/
.idea/
.DS_Store

# venv / build artifacts
/.venv/
/venv/
/build/
/dist/
*.egg-info/
.venv-pw/

# deployed-champion exhibit transient telemetry
/tmp/codex_k8s_telemetry/
